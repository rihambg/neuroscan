# NeuroScan - Environment Variables
# Copy this file to .env and fill in values

# ─── Database ────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=neuroscan
DB_USER=neuroscan_user
DB_PASS=neuroscan_pass

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=neuroscan_super_secret_jwt_key_2025_change_in_prod
JWT_EXPIRES_IN=24h

# ─── RabbitMQ ────────────────────────────────────
RABBITMQ_URL=amqp://neuroscan:neuroscan_pass@rabbitmq:5672/neuroscan_vhost

# ─── Consul ──────────────────────────────────────
CONSUL_HOST=consul
CONSUL_PORT=8500

# ─── Frontend ────────────────────────────────────
REACT_APP_API_URL=http://localhost/api

# ─── AI Service ──────────────────────────────────
INFERENCE_VERSION=placeholder-v1.0
